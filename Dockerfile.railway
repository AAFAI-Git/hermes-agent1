# Hermes Agent — Railway-optimized image
#
# Same runtime as the stock Dockerfile (non-root Hermes user, Playwright deps,
# HERMES_HOME=/opt/data, tini PID 1) with a thin bootstrap that:
#   - Maps Railway $PORT → API_SERVER_PORT
#   - Enables the API server so /health answers for Railway health checks
#   - Requires API_SERVER_KEY when binding 0.0.0.0 (matches gateway security)
#
# Railway checklist (dashboard):
#   1. Service → Settings → Root Directory: repo root (default).
#   2. Build: Dockerfile path = Dockerfile.railway (or rely on railway.json).
#   3. Variables (minimum): API_SERVER_KEY=$(openssl rand -hex 32)
#   4. Add a Volume → mount path: /opt/data (5+ GB recommended).
#   5. Resources: ≥ 4 GB RAM / 2 vCPU if browser + Hindsight are enabled.
#   6. Default CMD: hermes gateway run (Railway may override — use same wording).
#
# https://github.com/AAFAI-Git/hermes-agent1

FROM ghcr.io/astral-sh/uv:0.11.6-python3.13-trixie@sha256:b3c543b6c4f23a5f2df22866bd7857e5d304b67a564f4feab6ac22044dde719b AS uv_source
FROM tianon/gosu:1.19-trixie@sha256:3b176695959c71e123eb390d427efc665eeb561b1540e82679c15e992006b8b9 AS gosu_source
FROM debian:13.4

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/hermes/.playwright

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential nodejs npm python3 ripgrep ffmpeg gcc python3-dev libffi-dev procps git openssh-client docker-cli tini ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Default UID/GID 1000 for volume ownership on Railway; entrypoint may remap.
RUN useradd -u 1000 -m -d /opt/data hermes

COPY --chmod=0755 --from=gosu_source /gosu /usr/local/bin/
COPY --chmod=0755 --from=uv_source /usr/local/bin/uv /usr/local/bin/uvx /usr/local/bin/

WORKDIR /opt/hermes

COPY package.json package-lock.json ./
COPY web/package.json web/package-lock.json web/

RUN npm install --prefer-offline --no-audit && \
    npx playwright install --with-deps chromium --only-shell && \
    (cd web && npm install --prefer-offline --no-audit) && \
    npm cache clean --force

COPY --chown=hermes:hermes . .

COPY --chmod=0755 docker/railway-entrypoint.sh /opt/hermes/docker/railway-entrypoint.sh

RUN cd web && npm run build

USER root
RUN chmod -R a+rX /opt/hermes

RUN uv venv && \
    uv pip install --no-cache-dir -e ".[all]" && \
    ln -sf /opt/hermes/.venv/bin/hermes /usr/local/bin/hermes

ENV HERMES_WEB_DIST=/opt/hermes/hermes_cli/web_dist
ENV HERMES_HOME=/opt/data
ENV PATH="/opt/data/.local/bin:${PATH}"

# Railway-friendly defaults (railway-entrypoint still honors overrides)
ENV API_SERVER_ENABLED=1
ENV API_SERVER_HOST=0.0.0.0

ENTRYPOINT [ "/usr/bin/tini", "-g", "--", "/opt/hermes/docker/railway-entrypoint.sh" ]

# Exec-form: first token must be a real binary on PATH. `gateway` alone is invalid.
CMD [ "hermes", "gateway", "run" ]
